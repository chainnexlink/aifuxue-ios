// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 用户相关 ====================

enum MembershipType {
  FREE
  VIP
}

enum GradeLevel {
  PRIMARY    // 小学
  JUNIOR     // 初中
  SENIOR     // 高中
  COLLEGE    // 大学
  ADULT      // 成人
}

model User {
  id                  String         @id @default(uuid())
  phone               String?        @unique
  openid              String?        @unique  // 微信openid
  unionid             String?        @unique  // 微信unionid
  nickname            String?
  avatar              String?
  role                String         @default("student") // student, parent, teacher
  gradeLevel          GradeLevel?
  province            String?
  city                String?
  membershipType      MembershipType @default(FREE)
  vipExpireAt         DateTime?
  parentPasswordHash  String?
  parentPasswordSalt  String?
  parentFailedCount   Int            @default(0)
  parentLockedUntil   DateTime?
  // 教师相关
  teacherVerified     Boolean        @default(false)
  // 积分相关
  credits             Int            @default(0)
  // 邀请注册关联
  referredByTeacherId String?
  referredByTeacher   User?          @relation("TeacherReferrals", fields: [referredByTeacherId], references: [id])
  referredStudents    User[]         @relation("TeacherReferrals")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  notes               Note[]
  exercises           Exercise[]
  exerciseAttempts    ExerciseAttempt[]
  mistakes            Mistake[]
  adWatchLogs         AdWatchLog[]
  creditTransactions  CreditTransaction[]
  appleTransactions   AppleTransaction[]

  @@map("users")
}

// ==================== 笔记相关 ====================

model Note {
  id              String    @id @default(uuid())
  userId          String
  title           String?
  subject         String?
  originalImages  String[]  // 原始图片URL列表
  originalOcr     String?   @db.Text
  markdownContent String?   @db.Text
  previewLength   Int       @default(20) // 预览行数百分比
  isLocked        Boolean   @default(true)
  status          String    @default("processing") // processing, completed, failed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])
  exercises       Exercise[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("notes")
}

// ==================== 练习相关 ====================

model Exercise {
  id            String    @id @default(uuid())
  userId        String
  noteId        String?
  questionsJson Json      // 题目JSON (含加密答案)
  totalCount    Int       @default(0)
  generatedAt   DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
  note          Note?     @relation(fields: [noteId], references: [id])
  attempts      ExerciseAttempt[]

  @@index([userId])
  @@map("exercises")
}

model ExerciseAttempt {
  id          String   @id @default(uuid())
  exerciseId  String
  userId      String
  answersJson Json
  score       Int?
  totalScore  Int?
  submittedAt DateTime @default(now())

  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([exerciseId])
  @@map("exercise_attempts")
}

// ==================== 错题相关 ====================

model Mistake {
  id             String    @id @default(uuid())
  userId         String
  imageUrls      String[]
  ocrText        String?   @db.Text
  wrongAnswer    String?   @db.Text
  knowledgePoint String?
  errorReason    String?
  subject        String?
  status         String    @default("processing") // processing, completed, failed
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  similarQuestions  SimilarQuestion[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("mistakes")
}

model SimilarQuestion {
  id            String   @id @default(uuid())
  mistakeId     String
  questionsJson Json
  createdAt     DateTime @default(now())

  mistake       Mistake  @relation(fields: [mistakeId], references: [id])
  attempts      SimilarAttempt[]

  @@map("similar_questions")
}

model SimilarAttempt {
  id                String   @id @default(uuid())
  similarQuestionId String
  userId            String
  answersJson       Json
  score             Int?
  submittedAt       DateTime @default(now())

  similarQuestion   SimilarQuestion @relation(fields: [similarQuestionId], references: [id])

  @@map("similar_attempts")
}

// ==================== 广告日志 ====================

model AdWatchLog {
  id        String   @id @default(uuid())
  userId    String
  adType    String   // note_unlock, exercise_generate, etc.
  watchedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, adType, watchedAt])
  @@map("ad_watch_logs")
}

// ==================== 官网内容管理 ====================

model WebContent {
  id        String   @id @default(uuid())
  section   String   // hero, features, about, faq, help, privacy, agreement, testimonials, stats
  key       String   // unique identifier within section
  title     String?
  content   Json     // flexible JSON content
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([section, key])
  @@index([section, isActive, sortOrder])
  @@map("web_contents")
}

// ==================== 管理员 ====================

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  VIEWER
}

model Admin {
  id            String        @id @default(uuid())
  username      String        @unique
  passwordHash  String
  name          String
  role          AdminRole     @default(ADMIN)
  isActive      Boolean       @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("admins")
}

// ==================== 积分系统 ====================

enum CreditTransactionType {
  REFERRAL              // 学生注册奖励
  MEMBERSHIP_DEDUCTION  // 抵扣会员购买
  QUOTA_DEDUCTION       // 抵扣消耗次数
  IAP_PURCHASE          // App Store 内购
}

model CreditTransaction {
  id            String                @id @default(uuid())
  teacherId     String
  amount        Int                   // 正数=获得, 负数=消费
  type          CreditTransactionType
  description   String?
  relatedUserId String?               // 关联用户(注册的学生ID)
  createdAt     DateTime              @default(now())

  teacher       User                  @relation(fields: [teacherId], references: [id])

  @@index([teacherId, createdAt(sort: Desc)])
  @@map("credit_transactions")
}

// ==================== Apple IAP ====================

model AppleTransaction {
  id                    String    @id @default(uuid())
  userId                String
  transactionId         String    @unique
  originalTransactionId String
  productId             String
  type                  String    // "autoRenewable" | "consumable"
  purchaseDate          DateTime
  expiresDate           DateTime?
  revocationDate        DateTime?
  environment           String    // "Production" | "Sandbox"
  createdAt             DateTime  @default(now())

  user                  User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("apple_transactions")
}
