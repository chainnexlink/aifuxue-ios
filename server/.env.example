# 数据库连接
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_study_app?schema=public"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"
PARENT_JWT_SECRET="parent-jwt-secret-change-in-production"
